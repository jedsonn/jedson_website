 {
  "uid": "arxiv:2606.17165v3",
  "drop": false,
  "field": "economics",
  "role": "method",
  "bullets": [
   "Simulation studies plus an empirical application to the Upworthy Research Archive of online headline A/B tests, examining whether LLM responses can substitute for human participants.",
   "Adapts surrogate endpoint theory to LLMs; the specific model is not stated, and outputs are calibrated to human outcomes with a falsification test and worst-case bias bounds.",
   "Raw LLM outputs recover only 39 percent of the human treatment effect, while nonparametric calibration closes the gap under surrogacy and comparability conditions."
  ],
  "bullet_provenance": "ai",
  "models": [],
  "open_weights": null,
  "validated": true,
  "validation_note": "raw LLM recovers 39 percent of human treatment effect on Upworthy data",
  "salience": 70
 },
