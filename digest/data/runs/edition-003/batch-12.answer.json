 {
  "uid": "arxiv:2607.11414v1",
  "drop": false,
  "field": "finance",
  "role": "method",
  "bullets": [
   "Two financial question-answering benchmarks built from real filings, FinQA and TAT-QA, with answers generated by three open eight-to-nine-billion-parameter models.",
   "Linear probes trained on the residual stream of Qwen3-8B, Llama-3.1-8B and Gemma-2-9B flag confident hallucinations, benchmarked by AUROC against token log-probability and self-assessment baselines.",
   "Among answers where all eight resamples agree, 15 to 23 percent are wrong on FinQA; probes reach 0.68 to 0.77 AUROC versus 0.55 to 0.63 for the best baselines."
  ],
  "bullet_provenance": "ai",
  "models": [
   "llama",
   "open_other"
  ],
  "open_weights": true,
  "validated": true,
  "validation_note": "AUROC on FinQA and TAT-QA answer correctness",
