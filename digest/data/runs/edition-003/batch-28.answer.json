 {
  "uid": "doi:10.2139/ssrn.7053118",
  "drop": false,
  "field": "economics",
  "role": "method",
  "bullets": [
   "Case study using household income transfer data analyzed with quantile regression; sample size, period, and geography are not stated.",
   "LLMs, model not named, are asked to compute regression results directly from raw data, and their outputs are compared against computations run in Stata as the benchmark.",
   "The LLM produced fabricated coefficients that contradicted the Stata results, so the paper confines LLMs to conceptualization and code generation rather than native calculation."
  ],
  "bullet_provenance": "ai",
  "models": [],
  "open_weights": null,
  "validated": false,
  "validation_note": "compared to Stata output, no accuracy statistic reported",
  "salience": 43
 },
 {
  "uid": "doi:10.2139/ssrn.7053778",
  "drop": false,
  "field": "economics",
  "role": "method",
  "bullets": [
   "Methodological paper with simulations and an empirical application to news-based sentiment and stock returns; sample size, period, and geography are not stated.",
   "Gen-PI, a method-of-moments framework, corrects input-dependent bias in LLM-generated features using a small human-labeled calibration set and adaptive weights across model-prompt pairs; models are not named.",
   "Gen-PI cuts the confidence interval to roughly half the length obtained from human labels alone and stabilizes conclusions that naive LLM regressions leave sensitive to model and prompt choice."
  ],
  "bullet_provenance": "ai",
  "models": [],
  "open_weights": null,
  "validated": false,
  "validation_note": "human-labeled calibration set used for bias correction, no LLM accuracy figure",
  "salience": 74
 },
