<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ brand.name }}</title>
<meta name="description" content="{{ brand.tagline }}">
<link rel="alternate" type="application/rss+xml" title="{{ brand.name }}" href="feed.xml">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Public+Sans:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#14181d; --ink2:#565f6a; --ink3:#8b939e;
  --paper:#f6f7f9; --card:#ffffff; --rule:#e4e8ec; --rule2:#d0d6dd;
  --accent:#1a5276; --accent-soft:#eaf1f7;
  --ok:#2e6b52; --warn:#a06a1b;
  --sans:"Public Sans",system-ui,sans-serif;
  --serif:"Instrument Serif",Georgia,serif;
  --mono:"IBM Plex Mono",ui-monospace,monospace;
}
:root[data-theme="dark"]{
  --ink:#e8ebee; --ink2:#a3acb6; --ink3:#6f7883;
  --paper:#12151a; --card:#1a1f26; --rule:#2a313a; --rule2:#3a434d;
  --accent:#6ea6d6; --accent-soft:#1d2a35;
  --ok:#6cb494; --warn:#d0a25a;
}
*{box-sizing:border-box}
html,body{margin:0}
body{background:var(--paper);color:var(--ink);font-family:var(--sans);font-weight:400;
  font-size:15px;line-height:1.55;-webkit-font-smoothing:antialiased}
.wrap{max-width:940px;margin:0 auto;padding:0 24px 96px}
a{color:inherit}
:focus-visible{outline:2px solid var(--accent);outline-offset:3px}

/* ---- masthead ---- */
header.mast{padding:22px 0 18px;text-align:center}
.mast-top{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:20px}
.back{font-family:var(--mono);font-size:12px;color:var(--ink3);text-decoration:none}
.back:hover{color:var(--ink)}
.theme-btn{font-family:var(--mono);font-size:12px;background:transparent;border:1px solid var(--rule2);
  color:var(--ink2);border-radius:999px;padding:6px 14px;cursor:pointer;display:inline-flex;
  align-items:center;gap:7px;transition:all .15s}
.theme-btn:hover{border-color:var(--ink3);color:var(--ink)}
h1{font-family:var(--serif);font-weight:400;font-size:clamp(28px,4.6vw,40px);line-height:1;margin:0;letter-spacing:-.01em}
.tagline{font-size:14px;color:var(--ink2);margin:9px auto 0;max-width:56ch}
.tagline a{color:var(--accent);text-decoration:none}
.tagline a:hover{text-decoration:underline}
.mast-meta{font-family:var(--mono);font-size:11.5px;color:var(--ink3);margin-top:11px;letter-spacing:.02em}

/* ---- filter bar ---- */
.bar{position:sticky;top:0;z-index:20;background:var(--paper);
  border-top:1px solid var(--rule2);border-bottom:1px solid var(--rule2);
  padding:13px 0;margin-bottom:8px}
.bar-row{display:flex;gap:22px;align-items:center;flex-wrap:wrap;justify-content:center}
.fgroup{display:flex;align-items:center;gap:8px}
.flabel{font-family:var(--mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink3)}
.chips{display:flex;gap:6px;flex-wrap:wrap}
.chip{font-family:var(--sans);font-size:13px;font-weight:500;padding:5px 13px;border:1px solid var(--rule2);
  background:var(--card);color:var(--ink2);border-radius:999px;cursor:pointer;transition:all .12s;white-space:nowrap}
.chip:hover{border-color:var(--ink3);color:var(--ink)}
.chip[aria-pressed="true"]{background:var(--accent);border-color:var(--accent);color:#fff}
:root[data-theme="dark"] .chip[aria-pressed="true"]{color:#0d1115}
.bar-meta{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;
  margin-top:12px;font-family:var(--mono);font-size:12px;color:var(--ink3)}
.bar-meta .acts{display:flex;gap:16px}
.bar-meta button{background:none;border:0;font:inherit;color:var(--accent);cursor:pointer;padding:0;
  text-decoration:underline;text-underline-offset:3px}

/* ---- cards ---- */
main{margin-top:20px}
article{background:var(--card);border:1px solid var(--rule);border-radius:10px;
  padding:18px 22px;margin-bottom:12px;transition:border-color .12s}
article:hover{border-color:var(--rule2)}
.tags{font-family:var(--mono);font-size:10.5px;letter-spacing:.08em;text-transform:uppercase;
  color:var(--ink3);margin-bottom:8px;display:flex;gap:12px;flex-wrap:wrap;align-items:center}
.tags .role{font-weight:600;color:var(--accent)}
.tags .val{color:var(--ok)}
.chead{display:flex;gap:14px;align-items:flex-start;cursor:pointer}
.cnum{flex-shrink:0;font-family:var(--mono);font-size:12px;color:var(--ink3);
  padding-top:2px;min-width:34px;text-align:right;font-variant-numeric:tabular-nums}
.chead-main{flex:1;min-width:0}
h2.ptitle{font-size:14px;font-weight:500;line-height:1.35;margin:0;letter-spacing:0}
h2.ptitle a{color:var(--accent);text-decoration:none;border-bottom:1px solid transparent;transition:border-color .12s}
h2.ptitle a:hover{border-bottom-color:var(--accent)}
h2.ptitle .ext{font-size:10px;color:var(--ink3);margin-left:4px;white-space:nowrap}
.byline{font-size:12.5px;color:var(--ink);margin:5px 0 0;font-weight:500}
.byline a{color:var(--ink);text-decoration:none;border-bottom:1px dotted var(--rule2)}
.byline a:hover{color:var(--accent);border-bottom-color:var(--accent)}
.aff{font-size:12px;color:var(--ink3);margin:2px 0 0;font-weight:400}
.cites{font-size:11px;color:var(--ink3);font-family:var(--mono)}
.cites b{color:var(--ink2);font-weight:500}
.chev{flex-shrink:0;width:22px;height:22px;border:0;background:transparent;color:var(--ink3);
  cursor:pointer;display:flex;align-items:center;justify-content:center;margin-top:1px;transition:transform .18s}
article.open .chev{transform:rotate(90deg)}
.body{display:none;margin-top:15px;padding-top:15px;border-top:1px solid var(--rule)}
article.open .body{display:block}
dl{margin:0;display:grid;grid-template-columns:120px minmax(0,1fr);gap:10px 18px}
dt{font-family:var(--mono);font-size:10.5px;letter-spacing:.05em;text-transform:uppercase;
  color:var(--ink3);padding-top:3px}
dd{margin:0;font-size:13.5px;line-height:1.55;text-align:justify;hyphens:auto;-webkit-hyphens:auto}
.nobul{font-size:14px;color:var(--ink3);font-style:italic;margin:0}
.cfoot{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;
  margin-top:14px;font-family:var(--mono);font-size:10.5px;color:var(--ink3)}
.cfoot a{color:var(--accent);text-decoration:none;font-weight:500}
.cfoot a:hover{text-decoration:underline}
.empty{border:1px dashed var(--rule2);border-radius:10px;padding:56px 24px;text-align:center;color:var(--ink2)}
.empty p{margin:0 0 6px}

/* ---- footer ---- */
footer.site{border-top:1px solid var(--rule2);margin-top:48px;padding-top:22px;
  font-size:12.5px;color:var(--ink3);line-height:1.7;display:flex;justify-content:space-between;
  gap:16px;flex-wrap:wrap;align-items:baseline}
footer.site a{color:var(--accent);text-decoration:none}
footer.site a:hover{text-decoration:underline}
footer.site .links{font-family:var(--mono);font-size:12px}

/* ---- engage: subscribe + suggest ---- */
.engage{display:grid;grid-template-columns:1fr 1fr;gap:30px;margin-top:46px;padding-top:28px;border-top:1px solid var(--rule2)}
.eng-h{font-family:var(--serif);font-weight:400;font-size:21px;margin:0 0 5px;letter-spacing:-.01em}
.eng-p{font-size:13px;color:var(--ink2);margin:0 0 13px;line-height:1.5}
.eng-tabs{display:flex;gap:6px;margin:0 0 10px}
.eng-tab{font-family:var(--sans);font-size:12.5px;font-weight:500;padding:4px 12px;border:1px solid var(--rule2);
  background:var(--card);color:var(--ink2);border-radius:999px;cursor:pointer;transition:all .12s}
.eng-tab:hover{border-color:var(--ink3);color:var(--ink)}
.eng-tab[aria-pressed="true"]{background:var(--accent);border-color:var(--accent);color:#fff}
:root[data-theme="dark"] .eng-tab[aria-pressed="true"]{color:#0d1115}
.eng-form{display:flex;gap:8px}
.eng-form-col{flex-direction:column}
.eng-row{display:flex;gap:8px}
.eng-form input,.eng-form textarea{font:inherit;font-size:13.5px;color:var(--ink);background:var(--card);
  border:1px solid var(--rule2);border-radius:8px;padding:9px 11px;width:100%}
.eng-form textarea{min-height:72px;resize:vertical;line-height:1.5}
.eng-form input::placeholder,.eng-form textarea::placeholder{color:var(--ink3)}
.eng-form input:focus,.eng-form textarea:focus{outline:2px solid var(--accent);outline-offset:-1px;border-color:var(--accent)}
.eng-row input{flex:1}
.eng-btn{font-family:var(--sans);font-size:13.5px;font-weight:600;white-space:nowrap;
  background:var(--accent);color:#fff;border:0;border-radius:8px;padding:9px 18px;cursor:pointer;transition:filter .12s}
:root[data-theme="dark"] .eng-btn{color:#0d1115}
.eng-btn:hover{filter:brightness(1.08)}
.eng-btn:disabled{opacity:.55;cursor:default}
.eng-msg{font-size:12.5px;color:var(--ok);margin:9px 0 0;min-height:16px;font-weight:500}
.eng-msg.err{color:var(--warn)}

@media(max-width:600px){
  .engage{grid-template-columns:1fr;gap:32px}
  .wrap{padding:0 16px 60px}
  dl{grid-template-columns:1fr;gap:2px 0}
  dt{padding-top:9px}
  .bar-row{gap:14px}
}
@media(prefers-reduced-motion:reduce){*{transition:none!important}}
</style>
</head>
<body>
<div class="wrap">

<header class="mast">
  <div class="mast-top">
    <a class="back" href="https://www.jedsonpinto.com">&larr; jedsonpinto.com</a>
    <button type="button" class="theme-btn" id="theme" aria-label="Toggle dark mode">
      <span id="theme-ico">◐</span> <span id="theme-txt">Dark</span>
    </button>
  </div>
  <h1>{{ brand.name }}</h1>
  <p class="tagline">{{ brand.tagline }}.</p>
  <div class="mast-meta" id="mast-meta" data-date="{{ edition.date }}">&nbsp;</div>
</header>

<div class="bar">
  <div class="bar-row">
    <div class="fgroup">
      <span class="flabel">Field</span>
      <div class="chips" id="field-chips">
        <button class="chip" type="button" data-field="all" aria-pressed="true">All</button>
        <button class="chip" type="button" data-field="accounting" aria-pressed="false">Accounting</button>
        <button class="chip" type="button" data-field="finance" aria-pressed="false">Finance</button>
        <button class="chip" type="button" data-field="other" aria-pressed="false">Other</button>
      </div>
    </div>
    <div class="fgroup">
      <span class="flabel">When</span>
      <div class="chips" id="date-chips">
        <button class="chip" type="button" data-when="today" aria-pressed="false">Today</button>
        <button class="chip" type="button" data-when="week" aria-pressed="false">This week</button>
        <button class="chip" type="button" data-when="all" aria-pressed="true">All</button>
      </div>
    </div>
    <div class="fgroup">
      <span class="flabel">Scope</span>
      <div class="chips">
        <button class="chip" type="button" id="featured-toggle" aria-pressed="false" title="Papers from widely-cited researchers and leading departments">Featured <span id="feat-count" style="opacity:.6"></span></button>
        <button class="chip" type="button" id="tech-toggle" aria-pressed="false">Include technical <span id="tech-count" style="opacity:.6"></span></button>
      </div>
    </div>
  </div>
  <div class="bar-meta">
    <span id="status">Loading</span>
    <span class="acts">
      <button type="button" id="expand-all">Expand all</button>
      <button type="button" id="collapse-all">Collapse all</button>
    </span>
  </div>
</div>

<main id="list" aria-live="polite"></main>

<section class="engage" aria-label="Get involved">
  <div class="eng-col">
    <h3 class="eng-h">Get the digest</h3>
    <p class="eng-p">A short weekly email with the top new papers. At most one a week, and you can leave anytime.</p>
    <form class="eng-form" id="sub-form" novalidate>
      <input type="email" id="sub-email" required placeholder="you@university.edu" aria-label="Email address" maxlength="254" autocomplete="email">
      <button type="submit" class="eng-btn">Subscribe</button>
    </form>
    <p class="eng-msg" id="sub-msg" role="status" aria-live="polite"></p>
  </div>
  <div class="eng-col">
    <h3 class="eng-h">Suggest something</h3>
    <div class="eng-tabs" role="group" aria-label="Suggestion type">
      <button type="button" class="eng-tab" data-kind="paper" aria-pressed="true">A paper</button>
      <button type="button" class="eng-tab" data-kind="feature" aria-pressed="false">A feature</button>
    </div>
    <form class="eng-form eng-form-col" id="sug-form" novalidate>
      <input type="url" id="sug-link" placeholder="Link to the paper (SSRN, arXiv, DOI…)" aria-label="Paper link" maxlength="400">
      <textarea id="sug-body" required placeholder="What should we add, and why?" aria-label="Your suggestion" maxlength="4000"></textarea>
      <div class="eng-row">
        <input type="email" id="sug-contact" placeholder="Your email (optional)" aria-label="Your email, optional" maxlength="200" autocomplete="email">
        <button type="submit" class="eng-btn">Send</button>
      </div>
    </form>
    <p class="eng-msg" id="sug-msg" role="status" aria-live="polite"></p>
  </div>
</section>

<footer class="site">
  <span>Open metadata only (Crossref, arXiv, OpenAlex) &middot; no scraping &middot; summaries are ours, abstracts not reproduced. Corrections: <a href="mailto:{{ brand.contact_email }}">{{ brand.contact_email }}</a></span>
  <span class="links"><a href="feed.xml">RSS</a> &middot; <a href="data/papers.json">JSON</a></span>
</footer>

</div>

<script id="data" type="application/json">{{ payload }}</script>
<script>
(function(){
  var D = JSON.parse(document.getElementById("data").textContent);
  var papers = D.papers;
  var st = {field:"all", when:"all", tech:false, featured:false};

  // running archive record: total papers classified to date
  (function(){
    var m = document.getElementById("mast-meta");
    var total = papers.reduce(function(mx,p){ return Math.max(mx, p.n||0); }, papers.length);
    m.textContent = total + " papers classified · updated " + (m.dataset.date || "");
  })();

  // ----- theme (default light; remember choice) -----
  var root = document.documentElement;
  function setTheme(t){
    root.setAttribute("data-theme", t);
    document.getElementById("theme-txt").textContent = t==="dark" ? "Light" : "Dark";
    document.getElementById("theme-ico").textContent = t==="dark" ? "○" : "●";
    try{ localStorage.setItem("digest-theme", t); }catch(e){}
  }
  var saved; try{ saved = localStorage.getItem("digest-theme"); }catch(e){}
  setTheme(saved === "dark" ? "dark" : "light");
  document.getElementById("theme").addEventListener("click", function(){
    setTheme(root.getAttribute("data-theme")==="dark" ? "light" : "dark");
  });

  // ----- date helpers (relative to the viewer's clock) -----
  function daysAgo(n){ var d=new Date(); d.setDate(d.getDate()-n); return d.toISOString().slice(0,10); }
  var TODAY = new Date().toISOString().slice(0,10);
  var YESTERDAY = daysAgo(1);
  var WEEK = daysAgo(6);
  function inWhen(p){
    if (st.when==="all") return true;
    var d = p.posted || "";
    // "Today" also covers yesterday — postings lag a day and that is what
    // readers usually expect to see under "today".
    if (st.when==="today") return d >= YESTERDAY;
    if (st.when==="week")  return d >= WEEK;
    return true;
  }
  function inField(p){
    if (st.field==="all") return true;
    if (st.field==="other") return p.field!=="accounting" && p.field!=="finance";
    return p.field === st.field;
  }
  // Technical papers are hidden by default — EXCEPT work from top-50
  // institutions / prominent authors, which always stays visible.
  function inScope(p){ return st.tech || p.audience !== "technical" || p.prestige; }
  // "Featured" narrows to papers from widely-cited researchers / leading departments.
  function inFeatured(p){ return !st.featured || p.prestige; }
  function match(p){ return inField(p) && inWhen(p) && inScope(p) && inFeatured(p); }

  function esc(s){ return String(s||"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/"/g,"&quot;"); }

  function bylineHtml(p){
    var det = p.authors_detailed;
    if (det && det.length){
      return det.map(function(a){
        var nm = esc(a.name);
        var lab = a.inst ? ' title="'+esc(a.inst)+'"' : '';
        return a.url ? '<a href="'+esc(a.url)+'" target="_blank" rel="noopener"'+lab+'>'+nm+'</a>' : '<span'+lab+'>'+nm+'</span>';
      }).join(", ");
    }
    return esc((p.authors||[]).join(", "));
  }

  var SLOTS = ["Setting","What the model did","Result"];
  var PROV = {author:"Summary by the authors", editor:"Summary by the curator",
              ai:"Summary generated, checked", none:"Metadata only"};
  var FIELD_LABEL = {accounting:"Accounting", finance:"Finance", economics:"Economics",
                     management:"Management", other:"Other"};

  function card(p, i){
    var body;
    if (p.bullets && p.bullets.length===3){
      body = "<dl>" + p.bullets.map(function(b,j){
        return "<dt>"+SLOTS[j]+"</dt><dd>"+esc(b)+"</dd>"; }).join("") + "</dl>";
    } else {
      body = '<p class="nobul">No abstract was available from an open source, so this entry is a link only.</p>';
    }
    var prov = PROV[p.bullet_provenance] || "Metadata only";
    var val = p.validated===true ? ' · <span class="val">reports validation</span>' : "";
    var fieldLabel = FIELD_LABEL[p.field] || p.field;
    var cites = (typeof p.citations === "number" && p.citations > 0)
      ? '<span class="cites">Cited <b>'+p.citations+'</b></span>' : "";
    return '<article data-i="'+i+'">'
      + '<div class="chead" data-toggle="'+i+'">'
      +   '<div class="cnum" title="Position in the current view">'+(p._num||"")+'</div>'
      +   '<div class="chead-main">'
      +     '<div class="tags"><span>'+esc(fieldLabel)+'</span>'
      +       '<span>'+esc(p.posted)+'</span>'+cites+'</div>'
      +     '<h2 class="ptitle"><a href="'+esc(p.url)+'" rel="noopener" target="_blank">'+esc(p.title)
      +       '<span class="ext">&#8599;</span></a></h2>'
      +     '<p class="byline">'+bylineHtml(p)+'</p>'
      +     (p.affiliations && p.affiliations.length ? '<p class="aff">'+esc(p.affiliations.join(" · "))+'</p>' : '')
      +   '</div>'
      +   '<button class="chev" type="button" aria-label="Expand summary" data-toggle="'+i+'">'
      +     '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>'
      +   '</button>'
      + '</div>'
      + '<div class="body">' + body
      +   '<div class="cfoot"><span>'+esc(p.source_label)+' · '+prov+val+'</span>'
      +     '<a href="'+esc(p.url)+'" rel="noopener" target="_blank">Open paper &#8599;</a></div>'
      + '</div>'
      + '</article>';
  }

  function render(){
    var rows = papers.filter(match);
    // Default order: most recently posted first. Within a day, US top
    // universities float to the very top, then other featured work (international
    // schools, highly-cited authors), then the rest.
    rows.sort(function(a,b){
      var pd = String(b.posted||"").localeCompare(String(a.posted||""));
      if (pd !== 0) return pd;
      var ua = a.us_top?1:0, ub = b.us_top?1:0;
      if (ub !== ua) return ub - ua;
      var pa = a.prestige?1:0, pb = b.prestige?1:0;
      if (pb !== pa) return pb - pa;
      if ((b.salience||0)!==(a.salience||0)) return (b.salience||0)-(a.salience||0);
      return (b.n||0)-(a.n||0);
    });
    // The left-hand number counts the CURRENT view: the newest paper on top
    // is numbered with the visible total and it counts down to 1.
    rows.forEach(function(p, i){ p._num = rows.length - i; });
    document.getElementById("status").textContent =
      rows.length + " of " + papers.length + " papers";
    var list = document.getElementById("list");
    list.innerHTML = rows.length
      ? rows.map(card).join("")
      : '<div class="empty"><p>Nothing matches that filter yet.</p>'
        + '<p style="font-size:13px;color:var(--ink3)">Try widening the field or the date range.</p></div>';
    list.querySelectorAll("[data-toggle]").forEach(function(el){
      el.addEventListener("click", function(e){
        if (e.target.closest("a")) return; // let title/link clicks through
        var art = el.closest("article");
        art.classList.toggle("open");
        var open = art.classList.contains("open");
        art.querySelector(".chev").setAttribute("aria-label", open ? "Collapse summary" : "Expand summary");
      });
    });
  }

  function setAll(open){
    document.querySelectorAll("#list article").forEach(function(a){ a.classList.toggle("open", open); });
  }
  document.getElementById("expand-all").addEventListener("click", function(){ setAll(true); });
  document.getElementById("collapse-all").addEventListener("click", function(){ setAll(false); });

  document.getElementById("field-chips").addEventListener("click", function(e){
    var b = e.target.closest(".chip"); if (!b) return;
    st.field = b.dataset.field;
    this.querySelectorAll(".chip").forEach(function(c){ c.setAttribute("aria-pressed", c===b); });
    render();
  });
  document.getElementById("date-chips").addEventListener("click", function(e){
    var b = e.target.closest(".chip"); if (!b) return;
    st.when = b.dataset.when;
    this.querySelectorAll(".chip").forEach(function(c){ c.setAttribute("aria-pressed", c===b); });
    render();
  });

  // technical-scope toggle: technical papers hidden by default
  var techN = papers.filter(function(p){ return p.audience === "technical"; }).length;
  document.getElementById("tech-count").textContent = techN;
  document.getElementById("tech-toggle").addEventListener("click", function(){
    st.tech = !st.tech;
    this.setAttribute("aria-pressed", st.tech);
    render();
  });

  // featured toggle (off by default): prominent authors / leading departments
  var featN = papers.filter(function(p){ return p.prestige; }).length;
  document.getElementById("feat-count").textContent = featN;
  document.getElementById("featured-toggle").addEventListener("click", function(){
    st.featured = !st.featured;
    this.setAttribute("aria-pressed", st.featured);
    render();
  });

  render();
})();
</script>

<!-- Subscribe + suggest. Reuses the site's Supabase project ("rumo"). Degrades
     silently if the CDN is blocked. web_feedback insert emails the curator. -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
(function(){
  var SB_URL="https://nmkbznbjgfuqopezfncs.supabase.co";
  var SB_KEY="sb_publishable_NuyK_vdjUJnxNPfOww8XNw_fsZ84bk0";
  if(!window.supabase||!window.supabase.createClient) return;
  var sb; try{ sb=window.supabase.createClient(SB_URL,SB_KEY); }catch(e){ return; }
  var EMAIL=/^[^@\s]+@[^@\s]+\.[^@\s]+$/;
  function say(el,text,err){ if(!el)return; el.textContent=text; el.classList.toggle("err",!!err); }

  // ----- subscribe -----
  var subForm=document.getElementById("sub-form");
  if(subForm) subForm.addEventListener("submit",function(e){
    e.preventDefault();
    var email=document.getElementById("sub-email").value.trim();
    var m=document.getElementById("sub-msg");
    if(!EMAIL.test(email)){ say(m,"Please enter a valid email.",true); return; }
    var btn=subForm.querySelector("button"); btn.disabled=true;
    sb.from("web_subscribers").insert({email:email,source:"digest"}).then(function(r){
      btn.disabled=false;
      if(r.error){
        if(r.error.code==="23505"||/duplicate|unique/i.test(r.error.message||"")){ say(m,"You’re already on the list — thank you."); subForm.reset(); }
        else { say(m,"Something went wrong. Please try again later.",true); }
      } else { say(m,"You’re on the list — thank you."); subForm.reset(); }
    }).catch(function(){ btn.disabled=false; say(m,"Something went wrong. Please try again later.",true); });
  });

  // ----- suggest a paper / feature -----
  var kind="paper";
  var tabs=[].slice.call(document.querySelectorAll(".eng-tab"));
  var linkEl=document.getElementById("sug-link");
  tabs.forEach(function(t){ t.addEventListener("click",function(){
    kind=t.dataset.kind;
    tabs.forEach(function(x){ x.setAttribute("aria-pressed",String(x===t)); });
    if(linkEl) linkEl.style.display=(kind==="paper")?"":"none";
  }); });
  var sugForm=document.getElementById("sug-form");
  if(sugForm) sugForm.addEventListener("submit",function(e){
    e.preventDefault();
    var bodyEl=document.getElementById("sug-body");
    var body=bodyEl.value.trim();
    var m=document.getElementById("sug-msg");
    if(!body){ bodyEl.focus(); return; }
    var link=(linkEl?linkEl.value.trim():"");
    var contact=document.getElementById("sug-contact").value.trim();
    var full=(kind==="paper"&&link)?("Link: "+link+"\n\n"+body):body;
    var btn=sugForm.querySelector("button[type=submit]"); btn.disabled=true;
    sb.from("web_feedback").insert({
      kind:"suggestion", page:"digest",
      paper_title:(kind==="paper"?"Paper suggestion":"Feature request"),
      body:full.slice(0,5000), contact:contact.slice(0,200),
      user_agent:(navigator.userAgent||"").slice(0,400)
    }).then(function(r){
      btn.disabled=false;
      if(r.error){ say(m,"Something went wrong. Please try again later.",true); }
      else { say(m,"Sent to Jedson — thank you!"); sugForm.reset(); if(linkEl) linkEl.style.display=(kind==="paper")?"":"none"; }
    }).catch(function(){ btn.disabled=false; say(m,"Something went wrong. Please try again later.",true); });
  });
})();
</script>
</body>
